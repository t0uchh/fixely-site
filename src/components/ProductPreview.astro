---
import fs from "node:fs";
import path from "node:path";
import Screenshot from "./Screenshot.astro";

// Détection à la compilation : on n'affiche une vraie capture que si le
// fichier existe réellement dans /public/screenshots/. Sinon, placeholder.
const dir = path.resolve("./public/screenshots");
const has = (file: string) => {
  try {
    return fs.existsSync(path.join(dir, file));
  } catch {
    return false;
  }
};

const dashboardOk = has("dashboard.png");
const mobileOk = has("portail-mobile.png");
---

<section class="border-y border-ink-300/30 bg-ink-900/[0.015]">
  <div class="mx-auto max-w-7xl px-5 py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">
        Le bureau et le terrain, en un coup d'œil
      </h2>
      <p class="mt-4 text-lg text-ink-700">
        Un tableau de bord clair pour piloter, une app mobile efficace pour
        exécuter.
      </p>
    </div>

    <div class="relative mt-14">
      <!-- Capture dashboard (ou placeholder) -->
      {
        dashboardOk ? (
          <Screenshot
            src="/screenshots/dashboard.png"
            alt="Tableau de bord Fixely"
            variant="browser"
            url="fixely.aegix.fr/dashboard"
            class="lg:mr-24"
          />
        ) : (
          <div class="overflow-hidden rounded-2xl border border-dashed border-ink-300 bg-white shadow-xl lg:mr-24">
            <div class="flex items-center gap-1.5 border-b border-ink-300/30 bg-ink-900/[0.03] px-4 py-2.5">
              <span class="h-2.5 w-2.5 rounded-full bg-red-400" />
              <span class="h-2.5 w-2.5 rounded-full bg-amber-400" />
              <span class="h-2.5 w-2.5 rounded-full bg-green-400" />
              <span class="ml-3 rounded-md bg-white px-3 py-1 text-[11px] text-ink-500 shadow-sm">fixely.aegix.fr/dashboard</span>
            </div>
            <div class="flex aspect-[16/9] flex-col items-center justify-center gap-3 bg-brand-50/40 text-center">
              <svg class="h-12 w-12 text-brand-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
              <p class="text-sm font-medium text-ink-500">Capture dashboard à venir</p>
              <p class="max-w-xs text-xs text-ink-300">Déposez <code class="rounded bg-white px-1 py-0.5 text-brand-600">dashboard.png</code> dans /public/screenshots/</p>
            </div>
          </div>
        )
      }

      <!-- Capture mobile superposée (ou placeholder) -->
      <div class="mt-8 lg:absolute lg:-bottom-10 lg:right-0 lg:mt-0 lg:w-64">
        {
          mobileOk ? (
            <Screenshot
              src="/screenshots/portail-mobile.png"
              alt="Portail client Fixely sur mobile"
              variant="phone"
            />
          ) : (
            <div class="mx-auto w-full max-w-[260px]">
              <div class="rounded-[2.25rem] border-[6px] border-ink-900 bg-ink-900 shadow-2xl">
                <div class="flex aspect-[9/19] flex-col items-center justify-center gap-2 rounded-[1.75rem] bg-brand-50 text-center">
                  <svg class="h-9 w-9 text-brand-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3" /></svg>
                  <p class="px-4 text-[11px] font-medium text-ink-500">Capture mobile à venir</p>
                </div>
              </div>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
