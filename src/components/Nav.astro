---
const links = [
  { href: "/fonctionnalites", label: "Fonctionnalités" },
  { href: "/metiers", label: "Métiers" },
  { href: "/tarifs", label: "Tarifs" },
];
---

<header
  id="site-nav"
  class="sticky top-0 z-50 border-b border-transparent bg-white/80 backdrop-blur-md transition-all"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-5 py-3.5">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5">
      <img src="/logo.png" alt="Fixely" class="h-9 w-9" />
      <span class="text-lg font-extrabold tracking-tight text-ink-900">Fixely</span>
    </a>

    <!-- Liens desktop -->
    <div class="hidden items-center gap-1 md:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="rounded-lg px-3.5 py-2 text-sm font-medium text-ink-700 transition-colors hover:bg-brand-50 hover:text-brand-700"
          >
            {l.label}
          </a>
        ))
      }
    </div>

    <!-- CTA desktop -->
    <div class="hidden items-center gap-3 md:flex">
      <a
        href="https://my.fixely.app/"
        class="rounded-lg px-3.5 py-2 text-sm font-medium text-ink-700 transition-colors hover:text-brand-700"
        >Connexion</a
      >
      <a
        href="/demo"
        class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-all hover:bg-brand-700 hover:shadow"
        >Demander une démo</a
      >
    </div>

    <!-- Burger mobile -->
    <button
      id="burger"
      class="flex h-10 w-10 items-center justify-center rounded-lg text-ink-700 hover:bg-brand-50 md:hidden"
      aria-label="Menu"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Menu mobile -->
  <div id="mobile-menu" class="hidden border-t border-ink-300/30 bg-white px-5 py-4 md:hidden">
    <div class="flex flex-col gap-1">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-700 hover:bg-brand-50"
          >
            {l.label}
          </a>
        ))
      }
      <a
        href="https://my.fixely.app/"
        class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-700 hover:bg-brand-50"
        >Connexion</a
      >
      <a
        href="/demo"
        class="mt-2 rounded-lg bg-brand-600 px-4 py-2.5 text-center text-sm font-semibold text-white"
        >Demander une démo</a
      >
    </div>
  </div>
</header>

<script>
  const burger = document.getElementById("burger");
  const menu = document.getElementById("mobile-menu");
  burger?.addEventListener("click", () => menu?.classList.toggle("hidden"));

  // Ombre douce sur la nav au scroll
  const nav = document.getElementById("site-nav");
  const onScroll = () => {
    if (window.scrollY > 8) {
      nav?.classList.add("border-ink-300/40", "shadow-sm");
    } else {
      nav?.classList.remove("border-ink-300/40", "shadow-sm");
    }
  };
  window.addEventListener("scroll", onScroll);
  onScroll();
</script>
