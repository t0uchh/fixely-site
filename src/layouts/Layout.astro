---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Fixely — Logiciel de gestion des interventions terrain (FSM)",
  description = "Fixely digitalise vos interventions terrain : planification, app mobile technicien, formulaires métier, portail client et rapports PDF. Solution FSM clé en main.",
} = Astro.props;

// Suivi d'audience : beacon vers le backend Fixely (source 'site').
const TRACK_URL = import.meta.env.PUBLIC_TRACK_URL || "https://my.fixely.app/track/";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-ink-900 antialiased">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline define:vars={{ TRACK_URL }}>
      try {
        var payload = JSON.stringify({
          path: location.pathname + location.search,
          ref: document.referrer || "",
        });
        var blob = new Blob([payload], { type: "text/plain" });
        if (navigator.sendBeacon) {
          navigator.sendBeacon(TRACK_URL, blob);
        } else {
          fetch(TRACK_URL, {
            method: "POST", body: payload, mode: "no-cors", keepalive: true,
            headers: { "Content-Type": "text/plain" },
          });
        }
      } catch (e) {}
    </script>
  </body>
</html>
