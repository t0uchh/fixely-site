---
import Layout from "../layouts/Layout.astro";
import ProductPreview from "../components/ProductPreview.astro";

const universes = [
  {
    tag: "Bureau",
    color: "brand",
    title: "Pilotez depuis le bureau",
    points: [
      "Planning visuel & affectation glisser-déposer",
      "Tournées multi-étapes optimisées",
      "Tableau de bord temps réel + carte des techniciens",
      "Devis, factures et contrats liés aux interventions",
    ],
    icon: "M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2",
  },
  {
    tag: "Terrain",
    color: "accent",
    title: "Équipez vos techniciens",
    points: [
      "App mobile guidée étape par étape (GPS + horodatage)",
      "Formulaires métier dynamiques & CERFA",
      "Photos, signatures, compte-rendu",
      "Fonctionne même hors-ligne, synchro automatique",
    ],
    icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z",
  },
  {
    tag: "Client",
    color: "green",
    title: "Rassurez vos clients",
    points: [
      "Portail client en libre-service 24/7",
      "Suivi des interventions en temps réel",
      "Validation et téléchargement des rapports PDF",
      "Dépôt de demandes d'intervention",
    ],
    icon: "M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-1.13a4 4 0 10-4-4 4 4 0 004 4z",
  },
];

const steps = [
  { n: "01", t: "Demande", d: "Le client dépose une demande ou le bureau crée l'intervention." },
  { n: "02", t: "Planification", d: "Affectation au bon technicien, glisser-déposer sur le planning." },
  { n: "03", t: "Exécution", d: "Le technicien suit le workflow guidé : en route, arrivé, en cours." },
  { n: "04", t: "Rapport & signature", d: "Photos, formulaires, signature client sur mobile — même hors-ligne." },
  { n: "05", t: "Clôture", d: "Rapport PDF envoyé automatiquement, devis et facture liés." },
];

const diffs = [
  {
    title: "Vraie capacité hors-ligne",
    body: "Caves, parkings, zones blanches : vos techniciens travaillent sans réseau. Photos, signatures et formulaires se synchronisent au retour de la connexion.",
    icon: "M18.364 5.636a9 9 0 010 12.728m0 0l-2.829-2.829m2.829 2.829L21 21M15.536 8.464a5 5 0 010 7.072m0 0l-2.829-2.829m-4.243 2.829a4.978 4.978 0 01-1.414-2.83m-1.414 5.658a9 9 0 01-2.167-9.238m7.824 2.167a1 1 0 111.414 1.414m-1.414-1.414L3 3m8.293 8.293l1.414 1.414",
  },
  {
    title: "Formulaires métier sans code",
    body: "Chaque entreprise configure ses propres fiches d'intervention (15 types de champs) sans développeur. Conditions, alertes, validations incluses.",
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
  },
  {
    title: "Conformité CERFA / F-Gaz native",
    body: "Importez un CERFA officiel : Fixely le transforme en formulaire numérique et le remplit automatiquement, signatures comprises.",
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    title: "Multi-société natif",
    body: "Groupes, franchises, réseaux : gérez plusieurs sociétés sur une seule plateforme, avec des données strictement cloisonnées.",
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  },
];
---

<Layout>
  <!-- ════════════ HERO ════════════ -->
  <section class="relative overflow-hidden bg-grid">
    <div
      class="absolute inset-x-0 top-0 -z-10 h-[480px] bg-gradient-to-b from-brand-50/80 to-transparent"
    >
    </div>
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 pb-20 pt-16 lg:grid-cols-2 lg:pt-24">
      <!-- Texte -->
      <div class="animate-fade-up">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-accent-500"></span>
          Field Service Management
        </span>
        <h1 class="mt-5 text-4xl font-extrabold leading-[1.1] tracking-tight text-ink-900 sm:text-5xl lg:text-6xl">
          Vos interventions terrain,
          <span class="text-brand-600">enfin sous contrôle.</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-700">
          Fixely digitalise toute la chaîne — planification, exécution mobile,
          rapport client et facturation. Du bureau au terrain, plus rien ne se
          perd.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="/demo"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-brand-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/20 transition-all hover:bg-brand-700 hover:shadow-xl hover:shadow-brand-600/25"
          >
            Demander une démo
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a
            href="/fonctionnalites"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-ink-300 bg-white px-6 py-3.5 text-base font-semibold text-ink-700 transition-colors hover:border-brand-300 hover:text-brand-700"
          >
            Découvrir les fonctionnalités
          </a>
        </div>
        <p class="mt-4 text-sm text-ink-500">
          À partir de <a href="/tarifs" class="font-semibold text-brand-600 hover:underline">19 € HT / utilisateur / mois</a> — sans frais cachés.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-ink-500">
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Web + mobile iOS/Android
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Fonctionne hors-ligne
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Hébergement maîtrisé
          </span>
        </div>
      </div>

      <!-- Mockup visuel (dashboard + mobile) -->
      <div class="relative animate-fade-up" style="animation-delay: 0.15s">
        <!-- Dashboard -->
        <div class="rounded-2xl border border-ink-300/40 bg-white p-3 shadow-2xl shadow-brand-900/10">
          <div class="flex items-center gap-1.5 px-2 pb-2.5">
            <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>
            <span class="ml-2 text-[10px] font-medium text-ink-500">fixely.aegix.fr</span>
          </div>
          <div class="overflow-hidden rounded-xl bg-ink-900/[0.02] p-4">
            <div class="mb-3 flex items-center justify-between">
              <div>
                <div class="h-2.5 w-24 rounded-full bg-ink-900"></div>
                <div class="mt-1.5 h-1.5 w-16 rounded-full bg-ink-300"></div>
              </div>
              <div class="rounded-md bg-brand-600 px-2.5 py-1 text-[9px] font-bold text-white">+ Intervention</div>
            </div>
            <div class="grid grid-cols-4 gap-2">
              {[["Total","124","brand"],["En cours","8","accent"],["À valider","3","amber"],["Clôturées","87","green"]].map(([l,v,c]) => (
                <div class="rounded-lg border border-ink-300/30 bg-white p-2">
                  <div class="text-[8px] text-ink-500">{l}</div>
                  <div class={`text-base font-bold ${c==='brand'?'text-brand-600':c==='accent'?'text-accent-500':c==='amber'?'text-amber-500':'text-green-600'}`}>{v}</div>
                </div>
              ))}
            </div>
            <div class="mt-3 space-y-1.5">
              {[["INT-202606-0042","En cours","accent"],["INT-202606-0041","Planifiée","brand"],["INT-202606-0040","À valider","amber"]].map(([ref,st,c]) => (
                <div class="flex items-center justify-between rounded-lg border border-ink-300/30 bg-white px-2.5 py-2">
                  <span class="font-mono text-[9px] text-ink-700">{ref}</span>
                  <span class={`rounded-full px-2 py-0.5 text-[8px] font-semibold ${c==='accent'?'bg-orange-100 text-orange-700':c==='brand'?'bg-blue-100 text-blue-700':'bg-amber-100 text-amber-700'}`}>{st}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Téléphone superposé -->
        <div class="absolute -bottom-8 -right-2 w-40 rotate-3 sm:-right-6 sm:w-48">
          <div class="rounded-[1.75rem] border-[5px] border-ink-900 bg-ink-900 shadow-2xl">
            <div class="overflow-hidden rounded-[1.4rem] bg-white">
              <div class="bg-brand-600 px-3 pb-3 pt-4 text-white">
                <div class="text-[8px] opacity-80">Intervention</div>
                <div class="text-[11px] font-bold">INT-202606-0042</div>
                <span class="mt-1.5 inline-block rounded-full bg-white/20 px-2 py-0.5 text-[8px] font-semibold">En cours</span>
              </div>
              <div class="space-y-2 p-3">
                <div class="flex items-center gap-2 rounded-lg bg-green-50 px-2 py-1.5">
                  <span class="flex h-5 w-5 items-center justify-center rounded-full bg-green-500 text-[9px] text-white">✓</span>
                  <div class="h-1.5 w-16 rounded-full bg-green-200"></div>
                </div>
                <div class="flex items-center gap-2 rounded-lg bg-accent-500/10 px-2 py-1.5">
                  <span class="flex h-5 w-5 items-center justify-center rounded-full bg-accent-500 text-[9px] text-white">▶</span>
                  <div class="h-1.5 w-20 rounded-full bg-accent-400/40"></div>
                </div>
                <div class="rounded-lg bg-brand-600 py-2 text-center text-[9px] font-bold text-white">Terminer l'intervention</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════ BANDEAU CONFIANCE ════════════ -->
  <section class="border-y border-ink-300/30 bg-ink-900">
    <div class="mx-auto grid max-w-7xl grid-cols-2 gap-6 px-5 py-10 sm:grid-cols-4">
      {[["13","statuts de workflow tracés"],["100%","hors-ligne sur le terrain"],["15","types de champs métier"],["24/7","portail client en libre-service"]].map(([n,l]) => (
        <div class="text-center">
          <div class="text-3xl font-extrabold text-white sm:text-4xl">{n}</div>
          <div class="mt-1 text-xs text-ink-300 sm:text-sm">{l}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ════════════ APERÇU PRODUIT (captures réelles) ════════════ -->
  <ProductPreview />

  <!-- ════════════ 3 UNIVERS ════════════ -->
  <section class="mx-auto max-w-7xl px-5 py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">
        Une plateforme, trois univers
      </h2>
      <p class="mt-4 text-lg text-ink-700">
        Fixely connecte le bureau, le terrain et le client autour d'une même
        intervention.
      </p>
    </div>
    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        universes.map((u) => (
          <div class="group rounded-2xl border border-ink-300/40 bg-white p-7 transition-all hover:-translate-y-1 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-900/5">
            <div class={`flex h-12 w-12 items-center justify-center rounded-xl ${u.color==='brand'?'bg-brand-100 text-brand-600':u.color==='accent'?'bg-orange-100 text-accent-600':'bg-green-100 text-green-600'}`}>
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d={u.icon} /></svg>
            </div>
            <span class={`mt-5 inline-block text-xs font-bold uppercase tracking-wider ${u.color==='brand'?'text-brand-600':u.color==='accent'?'text-accent-600':'text-green-600'}`}>{u.tag}</span>
            <h3 class="mt-1 text-xl font-bold text-ink-900">{u.title}</h3>
            <ul class="mt-4 space-y-2.5">
              {u.points.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-ink-700">
                  <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {p}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ════════════ PARCOURS ════════════ -->
  <section class="border-y border-ink-300/30 bg-brand-50/40">
    <div class="mx-auto max-w-7xl px-5 py-20">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">
          Le parcours d'une intervention
        </h2>
        <p class="mt-4 text-lg text-ink-700">
          De la demande à la facture, chaque étape est tracée et automatisée.
        </p>
      </div>
      <div class="mt-14 grid gap-5 md:grid-cols-5">
        {
          steps.map((s, i) => (
            <div class="relative">
              <div class="rounded-2xl border border-ink-300/40 bg-white p-5">
                <div class="text-2xl font-extrabold text-brand-200">{s.n}</div>
                <h3 class="mt-2 font-bold text-ink-900">{s.t}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-ink-500">{s.d}</p>
              </div>
              {i < steps.length - 1 && (
                <div class="absolute -right-3 top-1/2 hidden -translate-y-1/2 text-brand-300 md:block">
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                </div>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ════════════ DIFFÉRENCIATEURS ════════════ -->
  <section class="mx-auto max-w-7xl px-5 py-20">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">
        Pourquoi Fixely ?
      </h2>
      <p class="mt-4 text-lg text-ink-700">
        Ce qui fait la différence sur le terrain comme au bureau.
      </p>
    </div>
    <div class="mt-14 grid gap-6 sm:grid-cols-2">
      {
        diffs.map((d) => (
          <div class="flex gap-5 rounded-2xl border border-ink-300/40 bg-white p-7">
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-brand-600 text-white">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d={d.icon} /></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-ink-900">{d.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-700">{d.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ════════════ CTA FINAL ════════════ -->
  <section class="mx-auto max-w-7xl px-5 pb-24">
    <div class="relative overflow-hidden rounded-3xl bg-brand-600 px-8 py-16 text-center shadow-2xl shadow-brand-600/20">
      <div class="bg-grid absolute inset-0 opacity-20"></div>
      <div class="relative">
        <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
          Prêt à digitaliser vos interventions ?
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-brand-100">
          Réservez une démo personnalisée : on vous montre Fixely sur votre cas
          métier, en 30 minutes. À partir de 19 € HT / utilisateur / mois.
        </p>
        <a
          href="/demo"
          class="mt-8 inline-flex items-center justify-center gap-2 rounded-xl bg-white px-7 py-3.5 text-base font-semibold text-brand-700 shadow-lg transition-transform hover:scale-[1.02]"
        >
          Demander une démo
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
