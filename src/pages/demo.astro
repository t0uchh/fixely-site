---
import Layout from "../layouts/Layout.astro";

const benefits = [
  "Une démo adaptée à votre métier (CVC, plomberie, élec, IT…)",
  "Le parcours complet : planning, mobile terrain, portail client",
  "Vos questions sur la reprise de données et l'intégration",
  "Sans engagement, en 30 minutes",
];
const metiers = ["CVC / Climatisation / Froid", "Plomberie / Chauffage", "Électricité", "IT / Télécom", "Multitechnique", "Autre"];
const tailles = ["1 à 5 techniciens", "6 à 20 techniciens", "21 à 50 techniciens", "50+ techniciens"];
---

<Layout title="Demander une démo — Fixely" description="Réservez une démo personnalisée de Fixely adaptée à votre métier. Sans engagement, en 30 minutes.">
  <section class="bg-grid">
    <div class="mx-auto grid max-w-7xl gap-12 px-5 py-16 lg:grid-cols-2 lg:py-24">
      <!-- Argumentaire -->
      <div>
        <span class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">
          <span class="h-1.5 w-1.5 rounded-full bg-accent-500"></span>
          Démo personnalisée
        </span>
        <h1 class="mt-5 text-4xl font-extrabold leading-tight tracking-tight text-ink-900 sm:text-5xl">
          Voyez Fixely sur <span class="text-brand-600">votre cas métier</span>
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-700">
          On vous montre concrètement comment Fixely s'adapte à vos
          interventions. Remplissez le formulaire, on vous recontacte sous 24h
          ouvrées.
        </p>
        <ul class="mt-8 space-y-3.5">
          {
            benefits.map((b) => (
              <li class="flex items-start gap-3 text-ink-700">
                <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-brand-100 text-brand-600">
                  <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                </span>
                <span class="text-[15px]">{b}</span>
              </li>
            ))
          }
        </ul>
        <div class="mt-10 rounded-2xl border border-ink-300/40 bg-white p-5">
          <p class="text-sm text-ink-500">Vous préférez écrire directement ?</p>
          <a href="mailto:contact@aegix.fr" class="mt-1 inline-flex items-center gap-2 font-semibold text-brand-600 hover:text-brand-700">
            contact@aegix.fr
          </a>
        </div>
      </div>

      <!-- Formulaire -->
      <div class="rounded-3xl border border-ink-300/40 bg-white p-7 shadow-xl shadow-brand-900/5 sm:p-9">
        <form id="demo-form" class="space-y-5">
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label class="mb-1.5 block text-sm font-medium text-ink-700" for="prenom">Prénom *</label>
              <input id="prenom" name="prenom" type="text" required class="w-full rounded-xl border border-ink-300 px-4 py-2.5 text-sm outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
            </div>
            <div>
              <label class="mb-1.5 block text-sm font-medium text-ink-700" for="nom">Nom *</label>
              <input id="nom" name="nom" type="text" required class="w-full rounded-xl border border-ink-300 px-4 py-2.5 text-sm outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
            </div>
          </div>
          <div>
            <label class="mb-1.5 block text-sm font-medium text-ink-700" for="societe">Société *</label>
            <input id="societe" name="societe" type="text" required class="w-full rounded-xl border border-ink-300 px-4 py-2.5 text-sm outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
          </div>
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label class="mb-1.5 block text-sm font-medium text-ink-700" for="email">Email pro *</label>
              <input id="email" name="email" type="email" required class="w-full rounded-xl border border-ink-300 px-4 py-2.5 text-sm outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
            </div>
            <div>
              <label class="mb-1.5 block text-sm font-medium text-ink-700" for="telephone">Téléphone</label>
              <input id="telephone" name="telephone" type="tel" class="w-full rounded-xl border border-ink-300 px-4 py-2.5 text-sm outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
            </div>
          </div>
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label class="mb-1.5 block text-sm font-medium text-ink-700" for="metier">Métier</label>
              <select id="metier" name="metier" class="w-full rounded-xl border border-ink-300 bg-white px-4 py-2.5 text-sm outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100">
                {metiers.map((m) => <option value={m}>{m}</option>)}
              </select>
            </div>
            <div>
              <label class="mb-1.5 block text-sm font-medium text-ink-700" for="taille">Taille d'équipe</label>
              <select id="taille" name="taille" class="w-full rounded-xl border border-ink-300 bg-white px-4 py-2.5 text-sm outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100">
                {tailles.map((t) => <option value={t}>{t}</option>)}
              </select>
            </div>
          </div>
          <div>
            <label class="mb-1.5 block text-sm font-medium text-ink-700" for="message">Votre besoin (optionnel)</label>
            <textarea id="message" name="message" rows="3" class="w-full rounded-xl border border-ink-300 px-4 py-2.5 text-sm outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100"></textarea>
          </div>
          <button type="submit" class="w-full rounded-xl bg-brand-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/20 transition-all hover:bg-brand-700">
            Réserver ma démo
          </button>
          <p class="text-center text-xs text-ink-500">
            En envoyant ce formulaire, vous acceptez d'être recontacté par
            l'équipe Fixely. Aucune donnée n'est partagée à des tiers.
          </p>
        </form>

        <!-- Message de succès -->
        <div id="demo-success" class="hidden text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-green-100 text-green-600">
            <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          </div>
          <h3 class="mt-5 text-xl font-bold text-ink-900">Demande envoyée !</h3>
          <p class="mt-2 text-ink-700">Merci, nous vous recontactons sous 24h ouvrées pour planifier votre démo.</p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById("demo-form") as HTMLFormElement | null;
    const success = document.getElementById("demo-success");
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      // TODO : brancher l'envoi réel.
      // Option A (recommandée) : POST vers un endpoint Django de Fixely
      //   await fetch("https://fixely.aegix.fr/api/demo-request/", { method:"POST", body: new FormData(form) })
      // Option B : service no-code (Web3Forms / Formspree) avec une clé publique.
      // Pour l'instant : feedback visuel local.
      const data = Object.fromEntries(new FormData(form).entries());
      console.log("Demande de démo :", data);
      form.classList.add("hidden");
      success?.classList.remove("hidden");
    });
  </script>
</Layout>
