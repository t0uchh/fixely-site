---
import Layout from "../layouts/Layout.astro";

const metiers = [
  { t: "CVC / Climatisation / Froid", d: "Maintenance, contrôles d'étanchéité F-Gaz, CERFA automatisés, suivi des fluides frigorigènes.", icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" },
  { t: "Plomberie / Chauffage", d: "Dépannages urgents, entretiens chaudières, recherches de fuite, devis sur place.", icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" },
  { t: "Électricité", d: "Installations, mises aux normes, maintenance préventive, attestations de conformité.", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { t: "IT / Télécom field service", d: "Déploiements, maintenances sur site, gestion de parc, interventions planifiées.", icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" },
  { t: "Multitechnique / Facility", d: "Coordination de corps de métier, contrats de maintenance multi-sites.", icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" },
  { t: "Ascensoristes / Levage", d: "Maintenance réglementaire, traçabilité des contrôles, historique par appareil.", icon: "M7 11l5-5m0 0l5 5m-5-5v12" },
  { t: "Espaces verts / Propreté", d: "Tournées récurrentes, passages planifiés, preuve de passage géolocalisée.", icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" },
  { t: "Et tout métier d'intervention", d: "Si un technicien se déplace chez un client avec un ordre d'intervention, Fixely est fait pour vous.", icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" },
];
---

<Layout title="Métiers — Fixely" description="Fixely s'adapte à tous les métiers d'intervention terrain : CVC, plomberie, électricité, IT, multitechnique, ascensoristes, espaces verts…">
  <section class="bg-grid border-b border-ink-300/30">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center lg:py-20">
      <h1 class="text-4xl font-extrabold tracking-tight text-ink-900 sm:text-5xl">
        Pensé pour <span class="text-brand-600">votre métier</span>
      </h1>
      <p class="mt-5 text-lg text-ink-700">
        Fixely s'adapte à chaque secteur d'intervention grâce à ses formulaires
        configurables et ses workflows sur mesure.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-16">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        metiers.map((m) => (
          <div class="rounded-2xl border border-ink-300/40 bg-white p-6 transition-all hover:-translate-y-1 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-900/5">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-100 text-brand-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d={m.icon} /></svg>
            </div>
            <h3 class="mt-4 font-bold text-ink-900">{m.t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-500">{m.d}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 pb-24">
    <div class="rounded-3xl bg-brand-600 px-8 py-14 text-center shadow-2xl shadow-brand-600/20">
      <h2 class="text-2xl font-extrabold text-white sm:text-3xl">Votre métier n'est pas listé ?</h2>
      <p class="mx-auto mt-3 max-w-xl text-brand-100">Fixely s'adapte. Montrons-vous comment lors d'une démo personnalisée.</p>
      <a href="/demo" class="mt-7 inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3.5 font-semibold text-brand-700 transition-transform hover:scale-[1.02]">
        Demander une démo
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      </a>
    </div>
  </section>
</Layout>
